package com.example.ects

import android.content.Context
import android.os.Bundle
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.Button
import android.widget.CheckBox
import android.widget.LinearLayout
import android.widget.TextView
import androidx.core.content.edit
import androidx.core.graphics.toColorInt
import androidx.fragment.app.Fragment

class PrzedmiotyFragment : Fragment() {

    private var zdobyteEcts = 0
    private lateinit var tvSumaEcts: TextView
    private lateinit var tvStatusEtapu: TextView
    private lateinit var kontenerNiezaliczonych: LinearLayout
    private lateinit var kontenerZaliczonych: LinearLayout

    private var numerSemestru = 1

    private val listaCheckBoxow = mutableListOf<Pair<Przedmiot, CheckBox>>()

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?,
    ): View? {
        return inflater.inflate(R.layout.fragment_przedmioty, container, false)
    }

    override fun onViewCreated(view: View, savedInstanceState: Bundle?) {
        super.onViewCreated(view, savedInstanceState)

        numerSemestru = arguments?.getInt("wybrany_semestr") ?: 1
        view.findViewById<TextView>(R.id.naglowekSemestru).text =
            getString(R.string.naglowek_semestru, numerSemestru)

        tvSumaEcts = view.findViewById(R.id.tvSumaEcts)
        tvStatusEtapu = view.findViewById(R.id.tvStatusEtapu)

        kontenerNiezaliczonych = view.findViewById(R.id.kontenerNiezaliczonych)
        kontenerZaliczonych = view.findViewById(R.id.kontenerZaliczonych)

        val btnZapisz = view.findViewById<Button>(R.id.btnZatwierdzIOblicz)
        btnZapisz.text = getString(R.string.zapisz_zaliczone)

        val listaPrzedmiotow = pobierzBazePrzedmiotow(numerSemestru)
        val prefs =
            requireActivity().getSharedPreferences(
                "ECTS_Prefs_Sem_$numerSemestru",
                Context.MODE_PRIVATE
            )

        zdobyteEcts = 0
        listaCheckBoxow.clear()

        // Przedmioty
        for (przedmiot in listaPrzedmiotow) {
            val checkBox =
                CheckBox(context).apply {
                    text =
                        getString(
                            R.string.przedmiot_format,
                            przedmiot.nazwa,
                            przedmiot.formaZajec,
                            przedmiot.ects
                        )
                    textSize = 14f
                    setPadding(0, 10, 0, 10)

                    val kluczZapisu = "${przedmiot.nazwa}_${przedmiot.formaZajec}"
                    val czyZaliczony = prefs.getBoolean(kluczZapisu, false)
                    isChecked = czyZaliczony

                    if (czyZaliczony) {
                        zdobyteEcts += przedmiot.ects
                    }

                    // zmienia punkty w locie ale elementy czekają na kliknięcie przycisku
                    setOnCheckedChangeListener { _, isChecked ->
                        if (isChecked) {
                            zdobyteEcts += przedmiot.ects
                        } else {
                            zdobyteEcts -= przedmiot.ects
                        }
                        przeliczEctsNaEkranie()
                    }
                }

            listaCheckBoxow.add(Pair(przedmiot, checkBox))

            przeniesDoKontenera(checkBox, checkBox.isChecked)
        }

        przeliczEctsNaEkranie()

        // Przycisk
        btnZapisz.setOnClickListener {
            prefs.edit {
                for ((przedmiot, cb) in listaCheckBoxow) {
                    val kluczZapisu = "${przedmiot.nazwa}_${przedmiot.formaZajec}"
                    putBoolean(kluczZapisu, cb.isChecked)
                    przeniesDoKontenera(cb, cb.isChecked)
                }
            }
        }
    }

    private fun przeniesDoKontenera(checkBox: CheckBox, doZaliczonych: Boolean) {
        (checkBox.parent as? ViewGroup)?.removeView(checkBox)

        if (doZaliczonych) {
            kontenerZaliczonych.addView(checkBox)
        } else {
            kontenerNiezaliczonych.addView(checkBox)
        }
    }

    private fun przeliczEctsNaEkranie() {
        tvSumaEcts.text = getString(R.string.suma_ects, zdobyteEcts)

        if (zdobyteEcts >= 30) {
            tvStatusEtapu.text = getString(R.string.status_pelne)
            tvStatusEtapu.setTextColor("#2E7D32".toColorInt())
        } else if (zdobyteEcts >= 15) {
            val deficyt = 30 - zdobyteEcts
            tvStatusEtapu.text = getString(R.string.status_warunkowe, deficyt)
            tvStatusEtapu.setTextColor("#EF6C00".toColorInt())
        } else {
            tvStatusEtapu.text = getString(R.string.status_brak)
            tvStatusEtapu.setTextColor("#D32F2F".toColorInt())
        }
    }

